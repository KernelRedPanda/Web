<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>CreaseXI — Virtual Cricket Manager</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --pitch: #2d5a1b;
  --pitch-light: #3d7a26;
  --cream: #f5f0e8;
  --gold: #c9a227;
  --gold-light: #e8c85a;
  --dark: #1a1a14;
  --text-light: #f0ead8;
  --text-muted: #8a8270;
}

body { font-family: 'DM Sans', sans-serif; background: var(--dark); color: var(--text-light); overflow-x: hidden; }

.pitch-bg {
  position: absolute;
  inset: 0;
  background:
    repeating-linear-gradient(90deg, transparent, transparent 48px, rgba(255,255,255,0.015) 48px, rgba(255,255,255,0.015) 50px),
    repeating-linear-gradient(0deg, transparent, transparent 48px, rgba(255,255,255,0.015) 48px, rgba(255,255,255,0.015) 50px);
  pointer-events: none;
}

.oval {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 900px;
  height: 500px;
  border-radius: 50%;
  border: 1px solid rgba(45,90,27,0.4);
  pointer-events: none;
}
.oval::before {
  content: '';
  position: absolute;
  inset: 30px;
  border-radius: 50%;
  border: 1px solid rgba(45,90,27,0.25);
}

.hero {
  min-height: 100vh;
  background: var(--dark);
  position: relative;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

nav {
  position: relative;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.5rem 3rem;
  border-bottom: 0.5px solid rgba(255,255,255,0.08);
}

.logo {
  font-family: 'Playfair Display', serif;
  font-size: 1.5rem;
  font-weight: 900;
  letter-spacing: -0.02em;
  color: var(--gold);
}
.logo span { color: var(--text-light); font-weight: 700; }

.nav-links { display: flex; gap: 2rem; align-items: center; }
.nav-links a { font-size: 0.85rem; color: var(--text-muted); text-decoration: none; letter-spacing: 0.05em; text-transform: uppercase; cursor: pointer; }
.nav-links a:hover { color: var(--gold); }

.btn-nav {
  background: var(--gold);
  color: var(--dark);
  border: none;
  padding: 0.5rem 1.25rem;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.8rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  border-radius: 2px;
  cursor: pointer;
}

.hero-content {
  position: relative;
  z-index: 10;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 3rem;
}

.season-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: rgba(201,162,39,0.12);
  border: 0.5px solid rgba(201,162,39,0.3);
  border-radius: 2px;
  padding: 0.35rem 0.85rem;
  font-size: 0.75rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 2rem;
}
.dot { width: 6px; height: 6px; border-radius: 50%; background: var(--gold-light); animation: pulse 2s ease-in-out infinite; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }

h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(3rem, 6vw, 5.5rem);
  font-weight: 900;
  line-height: 1.05;
  letter-spacing: -0.02em;
  margin-bottom: 1.5rem;
  max-width: 800px;
}
h1 em { font-style: italic; color: var(--gold); }

.hero-sub {
  font-size: 1.1rem;
  font-weight: 300;
  color: var(--text-muted);
  max-width: 520px;
  line-height: 1.8;
  margin-bottom: 3rem;
}

.cta-row { display: flex; gap: 1rem; align-items: center; }

.btn-primary {
  background: var(--gold);
  color: var(--dark);
  border: none;
  padding: 0.85rem 2rem;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9rem;
  font-weight: 500;
  letter-spacing: 0.05em;
  border-radius: 2px;
  cursor: pointer;
}
.btn-primary:hover { background: var(--gold-light); }

.btn-secondary {
  background: transparent;
  color: var(--text-light);
  border: 0.5px solid rgba(255,255,255,0.25);
  padding: 0.85rem 2rem;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9rem;
  font-weight: 400;
  letter-spacing: 0.05em;
  border-radius: 2px;
  cursor: pointer;
}
.btn-secondary:hover { border-color: rgba(255,255,255,0.5); }

.stats-strip {
  position: relative;
  z-index: 10;
  display: flex;
  justify-content: center;
  border-top: 0.5px solid rgba(255,255,255,0.08);
  padding: 1.5rem 3rem;
}
.stat-item {
  padding: 0 3rem;
  text-align: center;
  border-right: 0.5px solid rgba(255,255,255,0.08);
}
.stat-item:last-child { border-right: none; }
.stat-num { font-family: 'Playfair Display', serif; font-size: 1.8rem; font-weight: 700; color: var(--gold); }
.stat-label { font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); margin-top: 0.15rem; }

section { padding: 5rem 3rem; max-width: 1100px; margin: 0 auto; }

.section-tag {
  font-size: 0.72rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 1rem;
}
.section-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2rem, 3.5vw, 3rem);
  font-weight: 700;
  line-height: 1.15;
  margin-bottom: 1rem;
  color: var(--text-light);
}
.section-sub { font-size: 1rem; color: var(--text-muted); line-height: 1.8; max-width: 520px; }

.features-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  border: 0.5px solid rgba(255,255,255,0.08);
  margin-top: 3rem;
  background: rgba(255,255,255,0.08);
}

.feat-card {
  background: var(--dark);
  padding: 2rem;
}
.feat-icon {
  width: 40px;
  height: 40px;
  background: rgba(201,162,39,0.12);
  border: 0.5px solid rgba(201,162,39,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1.25rem;
  font-size: 18px;
}
.feat-title { font-size: 1rem; font-weight: 500; margin-bottom: 0.5rem; color: var(--text-light); }
.feat-desc { font-size: 0.85rem; color: var(--text-muted); line-height: 1.7; }

.team-section { background: rgba(255,255,255,0.02); border-top: 0.5px solid rgba(255,255,255,0.06); border-bottom: 0.5px solid rgba(255,255,255,0.06); }

.player-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  margin-top: 2.5rem;
  background: rgba(255,255,255,0.08);
  border: 0.5px solid rgba(255,255,255,0.08);
}

.player-card {
  background: #1e1e17;
  padding: 1.5rem 1.25rem;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.player-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: var(--gold);
  opacity: 0;
  transition: opacity 0.2s;
}
.player-card:hover::before { opacity: 1; }

.player-avatar {
  width: 52px;
  height: 52px;
  border-radius: 50%;
  background: rgba(201,162,39,0.15);
  border: 1px solid rgba(201,162,39,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Playfair Display', serif;
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--gold);
  margin: 0 auto 0.75rem;
}
.player-name { font-size: 0.9rem; font-weight: 500; color: var(--text-light); }
.player-role { font-size: 0.72rem; color: var(--text-muted); letter-spacing: 0.05em; margin-top: 0.2rem; }
.player-stat {
  margin-top: 0.75rem;
  font-size: 1.1rem;
  font-weight: 500;
  color: var(--gold);
  font-family: 'Playfair Display', serif;
}
.player-stat-label { font-size: 0.68rem; color: var(--text-muted); letter-spacing: 0.08em; }

.match-card {
  background: #1e1e17;
  border: 0.5px solid rgba(255,255,255,0.08);
  padding: 1.5rem 2rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1px;
}
.match-teams { font-size: 0.95rem; font-weight: 500; }
.match-vs { font-size: 0.75rem; color: var(--text-muted); margin: 0 0.5rem; }
.match-meta { font-size: 0.75rem; color: var(--text-muted); text-align: right; }
.match-week {
  background: rgba(201,162,39,0.12);
  border: 0.5px solid rgba(201,162,39,0.25);
  color: var(--gold);
  font-size: 0.68rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.2rem 0.6rem;
  border-radius: 2px;
}

.leaderboard {
  margin-top: 2.5rem;
  border: 0.5px solid rgba(255,255,255,0.08);
}
.lb-header {
  display: grid;
  grid-template-columns: 40px 1fr 60px 60px 60px 80px;
  padding: 0.75rem 1.25rem;
  border-bottom: 0.5px solid rgba(255,255,255,0.08);
  font-size: 0.68rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-muted);
  gap: 1rem;
}
.lb-row {
  display: grid;
  grid-template-columns: 40px 1fr 60px 60px 60px 80px;
  padding: 1rem 1.25rem;
  border-bottom: 0.5px solid rgba(255,255,255,0.06);
  align-items: center;
  font-size: 0.875rem;
  gap: 1rem;
}
.lb-row:last-child { border-bottom: none; }
.lb-row:first-of-type { background: rgba(201,162,39,0.05); }
.lb-pos { color: var(--text-muted); font-size: 0.8rem; }
.lb-pos.top { color: var(--gold); font-weight: 500; }
.lb-team { font-weight: 500; display: flex; align-items: center; gap: 0.5rem; }
.lb-dot { width: 8px; height: 8px; border-radius: 50%; }
.lb-pts { color: var(--gold); font-weight: 500; font-family: 'Playfair Display', serif; font-size: 1rem; }

.join-section {
  background: rgba(201,162,39,0.06);
  border-top: 0.5px solid rgba(201,162,39,0.2);
  text-align: center;
  padding: 5rem 3rem;
}

.form-row { display: flex; gap: 0.75rem; max-width: 420px; margin: 0 auto; }
.input-team {
  flex: 1;
  background: rgba(255,255,255,0.05);
  border: 0.5px solid rgba(255,255,255,0.15);
  border-radius: 2px;
  padding: 0.8rem 1rem;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9rem;
  color: var(--text-light);
  outline: none;
}
.input-team::placeholder { color: var(--text-muted); }
.input-team:focus { border-color: rgba(201,162,39,0.5); }

footer {
  border-top: 0.5px solid rgba(255,255,255,0.08);
  padding: 2rem 3rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.footer-logo { font-family: 'Playfair Display', serif; font-size: 1.1rem; font-weight: 700; color: var(--gold); }
.footer-copy { font-size: 0.75rem; color: var(--text-muted); }
</style>
</head>
<body>

<!-- HERO -->
<div class="hero">
  <div class="pitch-bg"></div>
  <div class="oval"></div>

  <nav>
    <div class="logo">Crease<span>XI</span></div>
    <div class="nav-links">
      <a href="#">Fixtures</a>
      <a href="#">My Squad</a>
      <a href="#">Transfers</a>
      <a href="#">League Table</a>
      <button class="btn-nav">Sign In</button>
    </div>
  </nav>

  <div class="hero-content">
    <div class="season-badge">
      <div class="dot"></div>
      Season 2026 · Week 18 of 30
    </div>
    <h1>Build your <em>dynasty.</em><br>Own the crease.</h1>
    <p class="hero-sub">Draft players, set tactics, and watch your team compete in fully simulated weekly matches. Pure strategy, no luck.</p>
    <div class="cta-row">
      <button class="btn-primary">Start managing free</button>
      <button class="btn-secondary">Watch a match →</button>
    </div>
  </div>

  <div class="stats-strip">
    <div class="stat-item">
      <div class="stat-num">48,200</div>
      <div class="stat-label">Active Managers</div>
    </div>
    <div class="stat-item">
      <div class="stat-num">3,840</div>
      <div class="stat-label">Live Leagues</div>
    </div>
    <div class="stat-item">
      <div class="stat-num">217</div>
      <div class="stat-label">Players Per Draft</div>
    </div>
    <div class="stat-item">
      <div class="stat-num">Weekly</div>
      <div class="stat-label">Match Day</div>
    </div>
  </div>
</div>

<!-- FEATURES -->
<div style="background: var(--dark);">
<section>
  <p class="section-tag">How it works</p>
  <h2 class="section-title">A full season in<br>your hands</h2>
  <p class="section-sub">Every Saturday, your tactics are locked in and matches simulate in real time. Adjust, trade, and adapt across 30 weeks.</p>

  <div class="features-grid">
    <div class="feat-card">
      <div class="feat-icon">⚾</div>
      <div class="feat-title">Weekly match simulation</div>
      <div class="feat-desc">Fully modeled ball-by-ball engine. Your lineup and batting order actually matter.</div>
    </div>
    <div class="feat-card">
      <div class="feat-icon">📋</div>
      <div class="feat-title">Tactics board</div>
      <div class="feat-desc">Set field placements, bowling rotations, and powerplay strategy before every fixture.</div>
    </div>
    <div class="feat-card">
      <div class="feat-icon">💱</div>
      <div class="feat-title">Transfer market</div>
      <div class="feat-desc">Bid on players mid-season. Release underperformers. Build your squad over time.</div>
    </div>
    <div class="feat-card">
      <div class="feat-icon">🏆</div>
      <div class="feat-title">Multi-tier leagues</div>
      <div class="feat-desc">Promotion and relegation every season. Rise from Division 4 to the Premier League.</div>
    </div>
    <div class="feat-card">
      <div class="feat-icon">📊</div>
      <div class="feat-title">Deep player stats</div>
      <div class="feat-desc">Batting average, strike rate, economy, wickets — every metric tracked across seasons.</div>
    </div>
    <div class="feat-card">
      <div class="feat-icon">🤝</div>
      <div class="feat-title">Private leagues</div>
      <div class="feat-desc">Create a private league for friends or your office. Commissioner controls the draft.</div>
    </div>
  </div>
</section>

<!-- SQUAD -->
<div class="team-section">
<section>
  <p class="section-tag">Squad view</p>
  <h2 class="section-title">Your 11 players,<br>your decisions</h2>

  <div class="player-grid">
    <div class="player-card">
      <div class="player-avatar">VK</div>
      <div class="player-name">V. Kumar</div>
      <div class="player-role">Top-order bat</div>
      <div class="player-stat">64.2</div>
      <div class="player-stat-label">avg this season</div>
    </div>
    <div class="player-card">
      <div class="player-avatar">RS</div>
      <div class="player-name">R. Shah</div>
      <div class="player-role">Pace bowler</div>
      <div class="player-stat">18</div>
      <div class="player-stat-label">wickets</div>
    </div>
    <div class="player-card">
      <div class="player-avatar">JM</div>
      <div class="player-name">J. Miller</div>
      <div class="player-role">Wicket-keeper</div>
      <div class="player-stat">41.5</div>
      <div class="player-stat-label">avg this season</div>
    </div>
    <div class="player-card">
      <div class="player-avatar">AH</div>
      <div class="player-name">A. Hassan</div>
      <div class="player-role">Spin bowler</div>
      <div class="player-stat">6.2</div>
      <div class="player-stat-label">economy</div>
    </div>
  </div>
</section>
</div>

<!-- FIXTURES -->
<section>
  <p class="section-tag">This week's fixtures</p>
  <h2 class="section-title">Round 18 results</h2>

  <div style="margin-top: 2.5rem;">
    <div class="match-card">
      <div>
        <div class="match-teams">Rajpur Royals <span class="match-vs">vs</span> Delhi Dynamoes</div>
        <div style="margin-top: 0.35rem; font-size: 0.78rem; color: var(--text-muted);">Premier Division · Saturday 3 May</div>
      </div>
      <div class="match-meta">
        <div class="match-week">Completed</div>
        <div style="color: #4caf50; font-size: 0.8rem; font-weight: 500; margin-top: 0.35rem;">Royals won by 34 runs</div>
      </div>
    </div>
    <div class="match-card">
      <div>
        <div class="match-teams">Kolkata Knights <span class="match-vs">vs</span> Chennai Superstars</div>
        <div style="margin-top: 0.35rem; font-size: 0.78rem; color: var(--text-muted);">Premier Division · Saturday 3 May</div>
      </div>
      <div class="match-meta">
        <div class="match-week">Completed</div>
        <div style="color: #f44336; font-size: 0.8rem; font-weight: 500; margin-top: 0.35rem;">Lost by 7 wickets</div>
      </div>
    </div>
    <div class="match-card" style="opacity: 0.6;">
      <div>
        <div class="match-teams">Mumbai Mavericks <span class="match-vs">vs</span> Hyderabad Heat</div>
        <div style="margin-top: 0.35rem; font-size: 0.78rem; color: var(--text-muted);">Premier Division · Saturday 10 May</div>
      </div>
      <div class="match-meta">
        <div class="match-week">Upcoming</div>
        <div style="margin-top: 0.35rem; font-size: 0.78rem; color: var(--text-muted);">Tactics close Fri 8pm</div>
      </div>
    </div>
  </div>
</section>

<!-- LEAGUE TABLE -->
<section>
  <p class="section-tag">Premier Division</p>
  <h2 class="section-title">League table</h2>

  <div class="leaderboard">
    <div class="lb-header">
      <span>#</span>
      <span>Team</span>
      <span style="text-align:center">W</span>
      <span style="text-align:center">L</span>
      <span style="text-align:center">NR</span>
      <span style="text-align:right">Pts</span>
    </div>
    <div class="lb-row">
      <span class="lb-pos top">1</span>
      <span class="lb-team"><span class="lb-dot" style="background:#c9a227"></span>Rajpur Royals</span>
      <span style="text-align:center">13</span>
      <span style="text-align:center">4</span>
      <span style="text-align:center">1</span>
      <span class="lb-pts" style="text-align:right">27</span>
    </div>
    <div class="lb-row">
      <span class="lb-pos">2</span>
      <span class="lb-team"><span class="lb-dot" style="background:#378add"></span>Chennai Superstars</span>
      <span style="text-align:center">11</span>
      <span style="text-align:center">5</span>
      <span style="text-align:center">2</span>
      <span class="lb-pts" style="text-align:right">24</span>
    </div>
    <div class="lb-row">
      <span class="lb-pos">3</span>
      <span class="lb-team"><span class="lb-dot" style="background:#4caf50"></span>Mumbai Mavericks</span>
      <span style="text-align:center">10</span>
      <span style="text-align:center">6</span>
      <span style="text-align:center">2</span>
      <span class="lb-pts" style="text-align:right">22</span>
    </div>
    <div class="lb-row">
      <span class="lb-pos">4</span>
      <span class="lb-team"><span class="lb-dot" style="background:#e24b4a"></span>Delhi Dynamoes</span>
      <span style="text-align:center">9</span>
      <span style="text-align:center">8</span>
      <span style="text-align:center">1</span>
      <span class="lb-pts" style="text-align:right">19</span>
    </div>
    <div class="lb-row">
      <span class="lb-pos">5</span>
      <span class="lb-team"><span class="lb-dot" style="background:#7f77dd"></span>Kolkata Knights</span>
      <span style="text-align:center">7</span>
      <span style="text-align:center">9</span>
      <span style="text-align:center">2</span>
      <span class="lb-pts" style="text-align:right">16</span>
    </div>
    <div class="lb-row" style="opacity:0.6">
      <span class="lb-pos">6</span>
      <span class="lb-team"><span class="lb-dot" style="background:#5f5e5a"></span>Hyderabad Heat</span>
      <span style="text-align:center">5</span>
      <span style="text-align:center">11</span>
      <span style="text-align:center">2</span>
      <span class="lb-pts" style="text-align:right">12</span>
    </div>
  </div>
</section>
</div>

<!-- JOIN -->
<div class="join-section">
  <p class="section-tag" style="text-align:center">Join the game</p>
  <h2 class="section-title" style="max-width:560px; margin:0 auto 1rem;">Ready to take the dug-out?</h2>
  <p class="section-sub" style="margin:0 auto 2.5rem; text-align:center">Name your team and register before the next draft. Season 2026 is live.</p>
  <div class="form-row">
    <input class="input-team" type="text" placeholder="Enter your team name..." />
    <button class="btn-primary">Join now</button>
  </div>
  <p style="font-size: 0.75rem; color: var(--text-muted); margin-top: 1rem;">Free to play · No credit card required</p>
</div>

<footer>
  <div class="footer-logo">CreaseXI</div>
  <div class="footer-copy">© 2026 CreaseXI · Virtual cricket management</div>
</footer>

</body>
</html>
